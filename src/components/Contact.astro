---
---

<section id="contact" class="relative py-[120px] px-6 overflow-hidden">

  <!-- Background decorative text -->
  <div
    class="absolute inset-0 flex items-center justify-center pointer-events-none z-0"
    aria-hidden="true"
  >
    <span class="text-[8rem] md:text-[16rem] font-black font-headline text-card leading-none whitespace-nowrap select-none">
      LET'S BUILD.
    </span>
  </div>

  <!-- Content -->
  <div class="relative z-10 max-w-screen-xl mx-auto text-center">

    <div class="mb-8">
      <span class="section-label" data-i18n="contact.label">CONTACT</span>
    </div>

    <h2
      class="text-5xl md:text-8xl font-black font-headline text-cream mb-4 fade-in"
      data-i18n="contact.title"
    >Let's Work Together</h2>

    <p
      class="font-mono text-sm text-muted mb-12 fade-in"
      data-i18n="contact.subtitle"
    >Open to freelance projects &amp; full-time roles in the US.</p>

    <div class="flex flex-col sm:flex-row justify-center gap-4 mb-16 fade-in">
      <a
        href="mailto:hello@frxncismor.dev"
        title="Send an email to Francisco Moreno"
        class="bg-brand text-[#2a1c84] font-bold py-4 px-10 tracking-widest text-xs hover:bg-brand-h transition-all font-mono"
        data-i18n="contact.email"
      >SEND AN EMAIL</a>
      <a
        href="https://github.com/frxncismor"
        title="Francisco Moreno on GitHub"
        target="_blank"
        rel="noopener noreferrer"
        class="border border-outline-v/40 text-cream font-bold py-4 px-10 tracking-widest text-xs hover:border-brand transition-all font-mono"
        data-i18n="contact.github"
      >GITHUB</a>
    </div>

    <p class="font-mono text-[11px] text-muted tracking-widest uppercase">frxncismor.dev</p>

  </div>

</section>
