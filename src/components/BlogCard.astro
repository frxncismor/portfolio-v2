---
interface Props {
  slug:        string
  titleEn:     string
  titleEs:     string
  descEn:      string
  descEs:      string
  category:    string
  date:        Date
}

const { slug, titleEn, titleEs, descEn, descEs, category, date } = Astro.props

const formatted = date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })
const formattedEs = date.toLocaleDateString('es-MX', { year: 'numeric', month: 'long', day: 'numeric' })
---

<a
  href={`/blog/${slug}`}
  title={`Read: ${titleEn}`}
  data-post-slug={slug}
  data-category={category}
  class="bg-card border-x border-b border-border rounded-[4px] p-8 flex flex-col gap-5 hover:-translate-y-1 transition-all duration-300 relative overflow-hidden group fade-in block"
  style="border-top: 2px solid #7F77DD;"
>
  <div class="flex justify-between items-start">
    <div class="flex flex-col gap-3">
      <span class="inline-block px-2 py-1 bg-white/5 border border-white/10 text-[9px] font-bold tracking-widest uppercase text-outline w-fit font-mono">
        {category}
      </span>
      <h3 class="text-2xl font-bold font-headline text-cream group-hover:text-brand transition-colors">
        <span class="lang-en">{titleEn}</span>
        <span class="lang-es">{titleEs}</span>
      </h3>
    </div>
    <span class="material-symbols-outlined text-outline group-hover:text-brand transition-colors" aria-hidden="true">
      arrow_outward
    </span>
  </div>

  <p class="text-sm font-mono leading-relaxed text-on-sv">
    <span class="lang-en">{descEn}</span>
    <span class="lang-es">{descEs}</span>
  </p>

  <div class="mt-auto">
    <span class="text-[10px] font-mono text-muted">
      <span class="lang-en">{formatted}</span>
      <span class="lang-es">{formattedEs}</span>
    </span>
  </div>
</a>
