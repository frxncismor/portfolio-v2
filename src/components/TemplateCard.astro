---
import type { Template } from '../data/templates'

interface Props {
  template: Template
}

const { template } = Astro.props
---

<a
  href={template.url}
  title={`Buy ${template.title} on Gumroad — $${template.price}`}
  target="_blank"
  rel="noopener noreferrer"
  class="bg-card border-x border-b border-border rounded-[4px] p-8 flex flex-col gap-6 hover:-translate-y-1 transition-all duration-300 relative overflow-hidden group fade-in block"
  style={`border-top: 2px solid ${template.accentColor};`}
>
  <div class="flex justify-between items-start">
    <div class="flex flex-col gap-3">
      <span class="inline-block px-2 py-1 bg-white/5 border border-white/10 text-[9px] font-bold tracking-widest uppercase text-outline w-fit font-mono">
        {template.category}
      </span>
      <h3 class="text-2xl font-bold font-headline text-cream">{template.title}</h3>
    </div>

    <div class="flex flex-col items-end gap-2 shrink-0 ml-4">
      <span
        class="text-xl font-black font-headline"
        style={`color: ${template.accentColor};`}
      >
        ${template.price}
      </span>
      <span class="material-symbols-outlined text-outline group-hover:text-brand transition-colors" aria-hidden="true">
        arrow_outward
      </span>
    </div>
  </div>

  <p class="text-sm font-mono leading-relaxed text-on-sv">{template.description}</p>

  <div class="mt-auto">
    <span class="text-[10px] text-muted block mb-2 font-bold tracking-widest uppercase font-mono">
      INCLUDES
    </span>
    <span class="text-[11px] font-mono text-cream/70">{template.features.join(' · ')}</span>
  </div>

  <span class="absolute bottom-4 right-4 text-[9px] font-mono text-muted group-hover:text-brand transition-colors uppercase tracking-widest">
    Buy on Gumroad ↗
  </span>
</a>
