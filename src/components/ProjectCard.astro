---
import type { Project } from '../data/projects'

interface Props {
  project: Project
}

const { project } = Astro.props

const primaryUrl   = project.url ?? project.githubUrl
const hasLink      = Boolean(primaryUrl)
const isGithubOnly = !project.url && Boolean(project.githubUrl)
const hasBothLinks = Boolean(project.url && project.githubUrl)
---

{hasLink ? (
  <a
    href={primaryUrl}
    title={isGithubOnly ? `View ${project.title} source code on GitHub` : `View ${project.title} — ${project.description}`}
    target="_blank"
    rel="noopener noreferrer"
    class="bg-card border-x border-b border-border rounded-[4px] p-8 flex flex-col gap-6 hover:-translate-y-1 transition-all duration-300 relative overflow-hidden group fade-in block"
    style={`border-top: 2px solid ${project.accentColor};`}
  >
    <div class="flex justify-between items-start">
      <div class="flex flex-col gap-3">
        <span class="inline-block px-2 py-1 bg-white/5 border border-white/10 text-[9px] font-bold tracking-widest uppercase text-outline w-fit font-mono">
          {project.category}
        </span>
        <h3 class="text-2xl font-bold font-headline text-cream">{project.title}</h3>
      </div>
      <span class="material-symbols-outlined text-outline group-hover:text-brand transition-colors" aria-hidden="true">
        {isGithubOnly ? 'code' : 'arrow_outward'}
      </span>
    </div>

    <p class="text-sm font-mono leading-relaxed text-on-sv">{project.description}</p>

    <div class="mt-auto">
      <span class="text-[10px] text-muted block mb-2 font-bold tracking-widest uppercase font-mono" data-i18n="work.stack-label">
        TECHNICAL STACK
      </span>
      <span class="text-[11px] font-mono text-cream/70">{project.stack.join(' · ')}</span>
    </div>

    {hasBothLinks && (
      <a
        href={project.githubUrl}
        title={`View ${project.title} source code on GitHub`}
        target="_blank"
        rel="noopener noreferrer"
        class="absolute bottom-4 right-4 text-[9px] font-mono text-muted hover:text-brand transition-colors uppercase tracking-widest"
        onclick="event.stopPropagation()"
      >GitHub ↗</a>
    )}
  </a>
) : (
  <article
    class="bg-card border-x border-b border-border rounded-[4px] p-8 flex flex-col gap-6 hover:-translate-y-1 transition-all duration-300 relative overflow-hidden group fade-in"
    style={`border-top: 2px solid ${project.accentColor};`}
  >
    <div class="flex justify-between items-start">
      <div class="flex flex-col gap-3">
        <span class="inline-block px-2 py-1 bg-white/5 border border-white/10 text-[9px] font-bold tracking-widest uppercase text-outline w-fit font-mono">
          {project.category}
        </span>
        <h3 class="text-2xl font-bold font-headline text-cream">{project.title}</h3>
      </div>
      <span class="text-[9px] font-mono text-muted uppercase tracking-widest pt-1">WIP</span>
    </div>

    <p class="text-sm font-mono leading-relaxed text-on-sv">{project.description}</p>

    <div class="mt-auto">
      <span class="text-[10px] text-muted block mb-2 font-bold tracking-widest uppercase font-mono" data-i18n="work.stack-label">
        TECHNICAL STACK
      </span>
      <span class="text-[11px] font-mono text-cream/70">{project.stack.join(' · ')}</span>
    </div>
  </article>
)}
