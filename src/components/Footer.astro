---

<footer class="w-full py-12 px-8 border-t border-white/10 bg-slate-950">
  <div class="flex flex-col md:flex-row justify-between items-center gap-6 max-w-screen-2xl mx-auto">

    <!-- Brand -->
    <div class="flex flex-col gap-1 items-center md:items-start">
      <span class="font-bold text-slate-100 font-headline tracking-tighter uppercase text-sm">
        FRXNCISMOR
      </span>
      <span class="font-mono text-[10px] tracking-widest uppercase text-slate-500" data-i18n="footer.tagline">
        Senior Web UI Engineer // Francisco Moreno
      </span>
    </div>

    <!-- Links -->
    <div class="flex gap-8">
      <a
        href="https://github.com/frxncismor"
        title="Francisco Moreno on GitHub"
        target="_blank"
        rel="noopener noreferrer"
        class="font-mono text-[10px] tracking-widest uppercase text-slate-500 hover:text-green transition-all duration-200"
        data-i18n="footer.github"
      >GitHub</a>
      <a
        href="https://linkedin.com/in/frxncismor"
        title="Francisco Moreno on LinkedIn"
        target="_blank"
        rel="noopener noreferrer"
        class="font-mono text-[10px] tracking-widest uppercase text-slate-500 hover:text-green transition-all duration-200"
        data-i18n="footer.linkedin"
      >LinkedIn</a>
    </div>

    <!-- Copyright -->
    <p
      class="font-mono text-[10px] tracking-widest uppercase text-slate-500 text-center md:text-right"
      data-i18n="footer.copy"
    >
      © 2024 FRANCISCO MORENO. ENGINEERED WITH PRECISION.
    </p>

  </div>
</footer>
