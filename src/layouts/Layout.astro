---
import '../styles/global.css'

interface Props {
  title?: string
  description?: string
  ogImage?: string
  keywords?: string
}

const {
  title       = 'Francisco Moreno — Senior Web UI Engineer',
  description = 'Angular specialist based in Houston, TX. 6 years building for Disney, Royal Caribbean, United Airlines & more. Available for freelance and full-time opportunities in the US.',
  ogImage     = '/og-image.svg',
  keywords    = 'Angular developer, TypeScript, React, Next.js, Astro, Frontend Engineer, Web Developer, Senior Web UI Engineer, Houston TX, freelance developer, JavaScript, Angular specialist',
} = Astro.props

const canonicalURL = new URL(Astro.url.pathname, Astro.site)
const ogImageURL   = new URL(ogImage, Astro.site)

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Francisco Moreno',
  url: 'https://frxncismor.dev',
  jobTitle: 'Senior Web UI Engineer',
  description: 'Angular specialist based in Houston, TX. 6 years building for Disney, Royal Caribbean, United Airlines & more.',
  knowsAbout: ['Angular', 'TypeScript', 'React', 'Next.js', 'Astro', 'JavaScript', 'Frontend Architecture', 'Web Development'],
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Houston',
    addressRegion: 'TX',
    addressCountry: 'US',
  },
  sameAs: [
    'https://github.com/frxncismor',
    'https://linkedin.com/in/frxncismor',
  ],
}

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Francisco Moreno',
  url: 'https://frxncismor.dev',
  description: 'Portfolio of Francisco Moreno — Senior Web UI Engineer based in Houston, TX.',
  author: { '@type': 'Person', name: 'Francisco Moreno', url: 'https://frxncismor.dev' },
  publisher: { '@type': 'Person', name: 'Francisco Moreno', url: 'https://frxncismor.dev' },
}
---

<!doctype html>
<html lang="en" class="dark" data-lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!--
      Inline lang-init: runs before body renders.
      Reads localStorage → sets data-lang → prevents EN flash when ES is stored.
      If ES is stored, sets opacity:0 so i18n.ts reveals after translations apply.
    -->
    <script is:inline>
      ;(function () {
        var lang = localStorage.getItem('lang') || 'en'
        document.documentElement.setAttribute('data-lang', lang)
        document.documentElement.setAttribute('lang', lang)
        if (lang === 'es') {
          document.documentElement.style.opacity = '0'
        }
      })()
    </script>

    <!-- Fonts: preconnect -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <!-- Non-render-blocking font loading (media=print trick) -->
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Epilogue:wght@400;700;800;900&family=DM+Mono:wght@400;500&display=swap"
    />
    <link
      rel="stylesheet"
      media="print"
      onload="this.media='all'"
      href="https://fonts.googleapis.com/css2?family=Epilogue:wght@400;700;800;900&family=DM+Mono:wght@400;500&display=swap"
    />
    <noscript>
      <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Epilogue:wght@400;700;800;900&family=DM+Mono:wght@400;500&display=swap" />
    </noscript>
    <!-- Material Symbols (icons) — non-render-blocking -->
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0&display=swap"
    />
    <link
      rel="stylesheet"
      media="print"
      onload="this.media='all'"
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0&display=swap"
    />
    <noscript>
      <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0&display=swap" />
    </noscript>

    <!-- Primary SEO -->
    <title>{title}</title>
    <meta name="description"  content={description} />
    <meta name="keywords"     content={keywords} />
    <meta name="author"       content="Francisco Moreno" />
    <meta name="publisher"    content="Francisco Moreno" />
    <link rel="canonical"     href={canonicalURL} />
    <meta name="robots"       content="index, follow" />
    <meta name="generator"    content={Astro.generator} />

    <!-- Open Graph -->
    <meta property="og:type"        content="website" />
    <meta property="og:url"         content={canonicalURL} />
    <meta property="og:title"       content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image"       content={ogImageURL} />
    <meta property="og:site_name"   content="frxncismor.dev" />
    <meta property="og:locale"      content="en_US" />

    <!-- Twitter Card -->
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:site"        content="@frxncismor" />
    <meta name="twitter:creator"     content="@frxncismor" />
    <meta name="twitter:url"         content={canonicalURL} />
    <meta name="twitter:title"       content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image"       content={ogImageURL} />

    <!-- JSON-LD Person + WebSite schemas -->
    <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="theme-color" content="#0c0c0f" />
  </head>
  <body class="antialiased">
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[100] focus:bg-brand focus:text-base focus:px-4 focus:py-2 focus:font-mono focus:text-xs focus:uppercase focus:tracking-widest"
    >Skip to content</a>
    <slot />
  </body>
</html>
